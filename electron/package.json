{
  "name": "salesdemo-electron",
  "version": "0.1.0",
  "description": "SalesDemo POS Application - Electron Wrapper",
  "main": "dist/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:vite": "cd ../frontend && npm run dev",
    "dev:electron": "npm run build:main && NODE_ENV=development electron .",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "cd ../frontend && npm run build",
    "build:main": "tsc -p tsconfig.json",
    "build:electron": "npm run build:main && electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "prestart": "npm run build:vite",
    "start": "npm run build:main && electron ."
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "@types/node": "^20.10.6",
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.6.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.salesdemo.pos",
    "productName": "SalesDemo POS",
    "files": [
      "dist/**/*",
      "../frontend/dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}

